{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paystack Balance API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Balance",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Fetch Balance",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paystack.co/balance"
          },
          "docs": "Check your Paystack account balance"
        },
        {
          "info": {
            "name": "Balance Ledger",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paystack.co/balance/ledger",
            "params": [
              {
                "name": "perPage",
                "value": "",
                "type": "query",
                "description": "Number of records to fetch per page"
              },
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "The section to retrieve"
              },
              {
                "name": "from",
                "value": "",
                "type": "query",
                "description": "The start date"
              },
              {
                "name": "to",
                "value": "",
                "type": "query",
                "description": "The end date"
              }
            ]
          },
          "docs": "Balance Ledger"
        }
      ]
    }
  ],
  "bundled": true
}
              },
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "The section to retrieve"
              },
              {
                "name": "customer",
                "value": "",
                "type": "query",
                "description": "Customer ID"
              },
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Invoice status to filter"
              },
              {
                "name": "currency",
                "value": "",
                "type": "query",
                "description": "If your integration supports more than one currency, choose the one to filter"

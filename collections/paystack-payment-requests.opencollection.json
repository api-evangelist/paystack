            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create Payment Request"
        },
        {
          "info": {
            "name": "Fetch Payment Request",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paystack.co/paymentrequest/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Fetch Payment Request"
        },
        {
          "info": {
            "name": "Update Payment Request",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.paystack.co/paymentrequest/:id",
            "params": [
              {
                "name": "id",
                "value": "",

{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paystack Payment Requests API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Payment Request",

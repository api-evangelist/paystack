              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update Payment Request"
        },
        {
          "info": {
            "name": "Verify Payment Request",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paystack.co/paymentrequest/verify/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Verify Payment Request"
        },
        {
          "info": {
            "name": "Send Notification",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.paystack.co/paymentrequest/notify/:id",

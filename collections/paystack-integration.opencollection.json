{
  "opencollection": "1.0.0",
  "info": {
    "name": "Paystack Integration Settings API",
    "version": "1.0.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Integration",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Fetch Payment Session Timeout",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.paystack.co/integration/payment_session_timeout"
          },
          "docs": "Fetch Payment Session Timeout"
        },
        {
          "info": {
            "name": "Update Payment Session Timeout",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.paystack.co/integration/payment_session_timeout",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update Payment Session Timeout"
        }
      ]
    }
  ],
  "bundled": true
}